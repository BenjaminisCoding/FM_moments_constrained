# Ignore everything by default
*

# Keep ignore rules file itself
!.gitignore

# Keep README
!README*
!Readme*

# Keep packaging/dependency metadata
!pyproject.toml

# Keep README-linked image assets
!Overleaf_paper/
!Overleaf_paper/Images/
!Overleaf_paper/Images/*.png

# Keep core project folders
!configs/
!configs/**
!scripts/
!scripts/**
!src/
!src/**
